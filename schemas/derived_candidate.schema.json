{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atticus.local/schemas/derived_candidate.v0.1.schema.json",
  "title": "ATTICUS MPPS Derived Candidate Packet v0.1",
  "type": "object",
  "required": [
    "packet_version",
    "packet_id",
    "packet_type",
    "candidate",
    "quality",
    "lineage",
    "review"
  ],
  "properties": {
    "packet_version": {"const": "mpps.derived.v0.1"},
    "packet_id": {"type": "string"},
    "packet_type": {"type": "string"},
    "candidate": {"type": "object"},
    "quality": {"type": "object"},
    "lineage": {
      "type": "object",
      "required": ["parent_packet_ids", "trace_id", "prov_bundle_id"],
      "properties": {
        "parent_packet_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "trace_id": {"type": "string"},
        "prov_bundle_id": {"type": "string"}
      }
    },
    "review": {
      "type": "object",
      "required": ["review_state", "human_review_required"],
      "properties": {
        "review_state": {"type": "string"},
        "human_review_required": {"type": "boolean"}
      }
    }
  }
}
